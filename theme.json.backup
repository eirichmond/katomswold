					"name": "Colorfour",
					"slug": "colorfour"
				},
				{
					"color": "#dead14",
					"name": "Colorfive",
					"slug": "colorfive"
				},
				{
					"color": "#a8af61",
					"name": "Colorsix",
					"slug": "colorsix"
				},
				{
					"color": "#ca3d52",
					"name": "Colorseven",
					"slug": "colorseven"
				},
				{
					"color": "#72b0bb",
					"name": "Coloreight",
					"slug": "coloreight"
				},
				{
					"color": "#d4dacc",
					"name": "Colornine",
					"slug": "colornine"
				},
				{
					"color": "#f5f1ce",
					"name": "Colorten",
					"slug": "colorten"
				},
				{
					"color": "#dfd9b7",
					"name": "Coloreleven",
					"slug": "coloreleven"
				},
				{
					"color": "#c9cb9a",
					"name": "Colortwelve",
					"slug": "colortwelve"
				},
				{
					"color": "#d6d9ce",
					"name": "Colorthirteen",
					"slug": "colorthirteen"
				},
				{
					"color": "#f2eddf",
					"name": "Colorfourteen",
					"slug": "colorfourteen"
				},
				{
					"color": "#e6dfd1",
					"name": "Colorfifteen",
					"slug": "colorfifteen"
				},
				{
					"color": "#c5c951",
					"name": "Titlecolorthree",
					"slug": "titlecolorthree"
				},
				{
					"color": "#dfe5d8",
					"name": "Section Separator",
					"slug": "sectionseparator"
				},
				{
					"color": "#fffced",
					"name": "Section Cotswolds",
					"slug": "sectioncotswolds"
				},
				{
					"color": "#f3f8ed",
					"name": "Section Coast",
					"slug": "sectioncoast"
				},
				{
					"color": "#f9fae5",
					"name": "Section Country",
					"slug": "sectioncountry"
				},
				{
					"color": "#c6b2a7",
					"name": "Special Offer",
					"slug": "specialoffer"
				},
				{
					"color": "#f7f7f7",
					"name": "Progress Bar",
					"slug": "progressbar"
				},
				{
					"color": "#d0d69a",
					"name": "Progress Active",
					"slug": "progressactive"
				},
				{
					"color": "#898169",
					"name": "Link Visit",
					"slug": "linkvisit"
				},
				{
					"color": "#efefef",
					"name": "Pale Grey",
					"slug": "palegrey"
				},
				{
					"color": "#333",
					"name": "Light Grey",
					"slug": "lightgrey"
				}
			]
		},
		"custom": {
			"spacing": {
				"large": "clamp(4rem, 10vw, 8rem)",
				"medium": "clamp(2rem, 8vw, calc(4 * var(--wp--style--block-gap)))",
				"outer": "var(--wp--custom--spacing--small, 1.25rem)",
				"small": "max(1.25rem, 5vw)"
			},
			"typography": {
				"font-size": {
					"colossal": "clamp(3.25rem, 8vw, 6.25rem)",
					"gigantic": "clamp(2.75rem, 6vw, 3.25rem)",
					"huge": "clamp(2.25rem, 4vw, 2.75rem)"
				},
				"line-height": {
					"large": 2,
					"medium": 1.5,
					"normal": 1,
					"small": 0
				}
			}
		},
		"layout": {
			"contentSize": "800px",
			"wideSize": "1200px"
		},
		"spacing": {
			"customSpacingSize": true,
			"defaultSpacingSizes": false,
			"spacingSizes": [
				{
					"name": "Tiny",
					"size": ".2em",
					"slug": "20"
				},
				{
					"name": "X Small",
					"size": ".5em",
					"slug": "30"
				},
				{
					"name": "Small",
					"size": "15px",
					"slug": "40"
				},
				{
					"name": "Medium",
					"size": "clamp(30px, 5vw, 50px)",
					"slug": "50"
				},
				{
					"name": "Large",
					"size": "clamp(40px, 7vw, 70px)",
					"slug": "60"
				},
				{
					"name": "X-Large",
					"size": "clamp(60px, 7vw, 90px)",
					"slug": "70"
				}
			],
			"units": [
				"%",
				"px",
				"em",
				"rem",
				"vh",
				"vw"
			]
		},
		"typography": {
			"customFontSize": false,
			"defaultFontSizes": false,
			"fontFamilies": [
				{
					"fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen-Sans, Ubuntu, Cantarell, 'Helvetica Neue', sans-serif",
					"name": "System Font",
					"slug": "system-font"
				}
			],
			"fontSizes": [
				{
					"fluid": false,
					"name": "X Small",
					"size": "0.75rem",
					"slug": "x-small"
				},
				{
					"fluid": false,
					"name": "Small",
					"size": "0.875rem",
					"slug": "small"
				},
				{
					"fluid": false,
					"name": "Medium",
					"size": "1.2rem",
					"slug": "medium"
				},
				{
					"fluid": {
						"max": "1.375rem",
						"min": "1.125rem"
					},
					"name": "Large",
					"size": "1.38rem",
					"slug": "large"
				},
				{
					"fluid": {
						"max": "2.5rem",
						"min": "1.75rem"
					},
					"name": "Extra Large",
					"size": "1.75rem",
					"slug": "x-large"
				},
				{
					"fluid": {
						"max": "3rem",
						"min": "2.15rem"
					},
					"name": "Extra Extra Large",
					"size": "2.15rem",
					"slug": "xx-large"
				}
			]
		},
		"useRootPaddingAwareAlignments": true
	},
	"styles": {
		"blocks": {
			"kate-and-toms/icon-button": {
				"border": {
					"radius": "3px"
				},
				"spacing": {
					"padding": {
						"bottom": "5px",
						"left": "0px",
						"right": "0px",
						"top": "5px"
					}
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)",
					"textTransform": "none"
				}
			},
			"core/button": {
				"border": {
					"radius": "3px"
				},
				"spacing": {
					"padding": {
						"bottom": "3px",
						"left": "0px",
						"right": "0px",
						"top": "3px"
					}
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)",
					"textTransform": "none"
				}
			},
			"core/heading": {
				"typography": {
					"lineHeight": "var(--wp--custom--typography--line-height--normal)"
				}
			},
			"core/navigation": {
				"spacing": {
					"blockGap": "var(--wp--preset--spacing--40)"
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			},
			"core/paragraph": {
				"typography": {
					"lineHeight": "var(--wp--custom--typography--line-height--medium)"
				}
			},
			"core/search": {
				"css": ".wp-block-search .wp-block-search__input {border-radius: 3px; padding: 3px 5px; border: none;}}",
				"spacing": {
					"margin": {
						"bottom": "0",
						"left": "0",
						"right": "0",
						"top": "0"
					}
				}
			}
		},
		"css": ":target {scroll-margin-top: 150px;}",
		"spacing": {
			"blockGap": "0"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--system-font)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"lineHeight": "var(--wp--custom--typography--line-height--medium)"
		}
	},
	"templateParts": [
		{
			"area": "header",
			"name": "header"
		},
		{
			"area": "footer",
			"name": "footer"
		}
	],
	"version": 3
}
