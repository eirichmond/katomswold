{
	"$schema": "https://schemas.wp.org/wp/6.8/theme.json",
	"settings": {
		"appearanceTools": true,
		"color": {
			"defaultPalette": false,
			"palette": [
				{
					"color": "#000000",
					"name": "Black",
					"slug": "black"
				},
				{
					"color": "#ffffff",
					"name": "White",
					"slug": "white"
				},
				{
					"color": "#e41817",
					"name": "Kate and Tom's Red",
					"slug": "kateandtomsred"
				},
				{
					"color": "#D40915",
					"name": "Primary",
					"slug": "primary"
				},
				{
					"color": "#FEFCEE",
					"name": "Secondary",
					"slug": "secondary"
				},
				{
					"color": "#F6F6F6",
					"name": "Tertiary",
					"slug": "tertiary"
				},
				{
					"color": "#343434",
